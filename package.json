{
  "name": "studiohub",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:homolog\" \"npm run server:dev\" \"npm --prefix studiohub-docs/guide run docs:dev\"",
    "dev:homolog": "vite --mode homologation",
    "dev:prod": "vite --mode production",
    "build": "tsc -b && vite build",
    "build:homolog": "tsc -b && vite build --mode homologation",
    "build:prod": "tsc -b && vite build --mode production",
    "preview": "vite preview",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:server": "vitest run --config vitest.server.config.ts",
    "test:server:coverage": "vitest run --config vitest.server.config.ts --coverage",
    "test:server:watch": "vitest --config vitest.server.config.ts",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "prepare": "husky",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "node --env-file .env.development --import tsx prisma/seed.ts",
    "db:studio": "node scripts/studio.mjs",
    "db:reset": "prisma migrate reset --force",
    "reset": "pnpm store prune && rm -rf node_modules pnpm-lock.yaml && pnpm install",
    "db:generate": "prisma generate",
    "server": "node --env-file .env.development --import tsx server/index.ts",
    "server:dev": "node --env-file .env.development --import tsx --watch server/index.ts",
    "docs:dev": "npm --prefix studiohub-docs/guide run docs:dev",
    "docs:build": "npm --prefix studiohub-docs/guide run docs:build",
    "docs:preview": "npm --prefix studiohub-docs/guide run docs:preview"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@hono/node-server": "^2.0.8",
    "@hono/swagger-ui": "^0.6.1",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-avatar": "^1.2.1",
    "@radix-ui/react-collapsible": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-scroll-area": "^1.2.1",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.2",
    "@radix-ui/react-tooltip": "^1.2.11",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "hono": "^4.12.27",
    "lucide-react": "^1.23.0",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "react-router-dom": "^7.18.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "4.1.9",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vitepress": "^2.0.0-alpha.18",
    "vitest": "^4.1.9"
  }
}
